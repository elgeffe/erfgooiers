{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "server/**/*.ts",
    "tests/server/**/*.ts",
    "src/net/protocol.ts",
    "src/game/ownership.ts",
    "src/types.ts"
  ]
}
